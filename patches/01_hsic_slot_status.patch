diff --git a/src/ifdhandler.c b/src/ifdhandler.c
index b746dfb..12eb08d 100644
--- a/src/ifdhandler.c
+++ b/src/ifdhandler.c
@@ -2056,6 +2056,35 @@ EXTERNAL RESPONSECODE IFDHICCPresence(DWORD Lun)
 			break;
 	}
 
+	if ((HSIC_CCID_READER == ccid_descriptor->readerID)
+		&& (IFD_ICC_NOT_PRESENT == return_value))
+	{
+		/* This reader has a broken PC_to_RDR_GetSlotStatus: bStatus always
+		 * reports "no ICC present", even while a card is inserted, powered
+		 * and exchanging APDUs.  Its interrupt endpoint DOES send correct
+		 * RDR_to_PC_NotifySlotChange messages, so trust the state learned
+		 * from them instead.  Right after startup (before any notification
+		 * was received) probe by powering the card: a successful power on
+		 * means a card is present. */
+		if (1 == ccid_descriptor->notified_presence)
+			return_value = IFD_ICC_PRESENT;
+		else if (-1 == ccid_descriptor->notified_presence)
+		{
+			unsigned char atr_probe[64];
+			unsigned int atr_probe_len = sizeof(atr_probe);
+
+			if (IFD_SUCCESS == CmdPowerOn(reader_index, &atr_probe_len,
+				atr_probe, VOLTAGE_AUTO))
+			{
+				(void)CmdPowerOff(reader_index);
+				ccid_descriptor->notified_presence = 1;
+				return_value = IFD_ICC_PRESENT;
+			}
+			else
+				ccid_descriptor->notified_presence = 0;
+		}
+	}
+
