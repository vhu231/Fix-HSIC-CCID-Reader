 	int dwSlotStatus;
 
+	/*
+	 * HSIC CCID-Reader slot status management
+	 * The reader always answers "no ICC present" to PC_to_RDR_GetSlotStatus,
+	 * even while a card is inserted and powered.  Its interrupt endpoint DOES
+	 * send correct RDR_to_PC_NotifySlotChange messages, so card presence is
+	 * tracked from those instead.
+	 * -1 = no notification seen yet, 0 = absent, 1 = present
+	 */
+	int notified_presence;
+
 	/*
 	 * bVoltageSupport (bit field)
 	 * 1 = 5.0V
@@ -290,6 +300,7 @@ typedef struct
 #define KAPELSE_KAPLIN2			0x29470105
 #define KAPELSE_KAPECV			0x29470112
 #define ACS_ACR122U				0x072f2200
